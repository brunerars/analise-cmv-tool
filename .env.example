# ============================================
# CMV Hub - Variáveis de Ambiente
# ============================================
# 
# Este arquivo documenta as variáveis de ambiente
# que podem ser usadas para configurar a aplicação.
#
# Para usar: copie este arquivo para .env e ajuste
# os valores conforme necessário.
# ============================================

# Configurações do Streamlit
# ---------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Configurações da Aplicação
# ---------------------------
APP_TITLE="CMV Hub | ARV Systems"
APP_ENVIRONMENT=production

# Configurações de Dados
# -----------------------
# Caminho para o arquivo CSV de dados
DATA_CSV_PATH=/app/data/processed/cmv_data.csv

# Caminho para o banco de dados SQLite
DATABASE_PATH=/app/data/cmv_catalog.db

# Caminho para armazenamento de imagens
IMAGES_PATH=/app/data/images

# Configurações de Segurança (Opcional)
# --------------------------------------
# Se você quiser adicionar autenticação no futuro
# ENABLE_AUTH=false
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# Configurações de Performance (Opcional)
# ----------------------------------------
# Tamanho máximo de upload de imagens (em MB)
MAX_IMAGE_SIZE_MB=5

# Cache do Streamlit (segundos)
CACHE_TTL_SECONDS=3600

# Configurações de Logging (Opcional)
# ------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Notas:
# - Variáveis de ambiente sobrescrevem configurações em config.toml
# - Para desenvolvimento local, use valores diferentes de produção
# - Nunca commite o arquivo .env no Git (já está no .gitignore)
# ============================================
